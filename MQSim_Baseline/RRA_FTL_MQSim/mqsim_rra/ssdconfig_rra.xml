<?xml version="1.0" encoding="utf-8" ?>
<!--
  ssdconfig_rra.xml
  ==================
  MQSim SSD configuration for RRA-FTL hackathon simulation.

  This config models a realistic NVMe SSD with:
    - 8 channels × 2 chips × 2 dies × 2 planes
    - 512 blocks per plane, 256 pages per block, 8 sectors per page
    - 10% over-provisioning (matches our Python sim)
    - GC threshold 0.05 (triggers when 5% of plane pages are free)
    - MLC NAND with PE endurance = 10,000 cycles
    - Erase time = 1.5 ms base (RRA-FTL will scale this per-block)

  KEY PARAMETER FOR RRA-FTL:
    GC_Block_Selection_Policy is set to GREEDY here because MQSim's
    XML parser does not know about "RRA_WEIBULL" yet.  The RRA-FTL
    code overrides the victim selection at runtime regardless of this
    setting (our Get_next_gc_victim() is called unconditionally).
    See GC_and_WL_Unit_Page_Level_RRA.h for details.

  To run BASELINE for comparison, use ssdconfig_baseline.xml
  which is identical except Preemptible_GC_Enabled = false and
  no RRA-FTL code is compiled in.
-->

<Sim_Config>

  <SSD_Device_Configuration>

    <!-- ── Channel / package topology ──────────────────────────────────── -->
    <Flash_Channel_Count>8</Flash_Channel_Count>
    <Chip_No_Per_Channel>2</Chip_No_Per_Channel>
    <Flash_Parameters>
      <Die_No_Per_Chip>2</Die_No_Per_Chip>
      <Plane_No_Per_Die>2</Plane_No_Per_Die>
      <Block_No_Per_Plane>512</Block_No_Per_Plane>
      <Page_No_Per_Block>256</Page_No_Per_Block>
      <Page_Capacity>4096</Page_Capacity>       <!-- 4 KB pages -->
      <Sector_Size_In_Byte>512</Sector_Size_In_Byte>

      <!-- ── NAND timing (MLC NAND) ──────────────────────────────────── -->
      <!--
        RRA-FTL ADAPTIVE ERASE:
        Read_One_Transfer_Time_NS is left at the standard value.
        Erase time here (1,500,000 ns = 1.5 ms) is the BASE value T_base.
        GC_and_WL_Unit_Page_Level_RRA::Set_erase_transaction_time()
        overrides the actual per-transaction time with:
          T_base * (1 + K_age * erase_count / PE_endurance)
        So a fresh block erases in 1.5 ms; a 90%-worn block takes 2.85 ms.
        This is injected directly into the TSU scheduling — MQSim's P99
        latency output will reflect the aging effect automatically.
      -->
      <Read_Latency_NS>40000</Read_Latency_NS>
      <Read_Transfer_NS>100000</Read_Transfer_NS>
      <Program_Latency_NS>200000</Program_Latency_NS>
      <Program_Transfer_NS>100000</Program_Transfer_NS>
      <Erase_Latency_NS>1500000</Erase_Latency_NS>     <!-- 1.5 ms base -->

      <!-- PE endurance — must match RRA_PE_ENDURANCE_DEFAULT in .h -->
      <Max_PE_Cycles>10000</Max_PE_Cycles>
    </Flash_Parameters>

    <!-- ── Host interface ────────────────────────────────────────────── -->
    <Host_Interface_Type>NVME</Host_Interface_Type>
    <Queue_Fetch_Size>512</Queue_Fetch_Size>
    <Caching_Mechanism>SIMPLE</Caching_Mechanism>
    <Data_Cache_Capacity_In_Page>1024</Data_Cache_Capacity_In_Page>

    <!-- ── FTL parameters ────────────────────────────────────────────── -->
    <Address_Mapping>PAGE_LEVEL</Address_Mapping>
    <Ideal_Mapping_Table>false</Ideal_Mapping_Table>
    <CMT_Capacity_In_Byte>1048576</CMT_Capacity_In_Byte>   <!-- 1 MB CMT -->

    <Transaction_Scheduling_Policy>OUT_OF_ORDER</Transaction_Scheduling_Policy>
    <Overprovisioning_Ratio>0.10</Overprovisioning_Ratio>

    <!-- ── GC parameters ─────────────────────────────────────────────── -->
    <!--
      GC_Exect_Threshold: start GC when free pages drop below 5% of plane.
      GC_Block_Selection_Policy: GREEDY is parsed by MQSim. RRA-FTL
        overrides victim selection at runtime regardless of this value.
    -->
    <GC_Exect_Threshold>0.05</GC_Exect_Threshold>
    <GC_Block_Selection_Policy>GREEDY</GC_Block_Selection_Policy>
    <Use_Copyback_for_GC>false</Use_Copyback_for_GC>
    <Preemptible_GC_Enabled>false</Preemptible_GC_Enabled>
    <GC_Hard_Threshold>0.005</GC_Hard_Threshold>

    <!-- ── Wear leveling (RRA-FTL handles WL via Weibull scoring) ─────── -->
    <Dynamic_Wearleveling_Enabled>false</Dynamic_Wearleveling_Enabled>
    <Static_Wearleveling_Enabled>false</Static_Wearleveling_Enabled>
    <Static_Wearleveling_Threshold>100</Static_Wearleveling_Threshold>

  </SSD_Device_Configuration>

</Sim_Config>
