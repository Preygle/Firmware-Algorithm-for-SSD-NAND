<?xml version="1.0" encoding="utf-8" ?>
<!--
  workload_sequential.xml
  ========================
  Sequential write workload — 100,000 writes, all LBAs 0..2879 cycling.
  Matches Python sim: generate_sequential(100_000)

  Run:
    ./MQSim -i ssdconfig_rra.xml -w workloads/workload_sequential.xml
    ./MQSim -i ssdconfig_baseline.xml -w workloads/workload_sequential.xml
-->
<MQSim_IO_Scenarios>
  <IO_Scenario>

    <IO_Flow_Parameter_Set_Trace_Based>
      <Priority_Class>URGENT</Priority_Class>
      <Device_Level_Data_Caching_Mode>NO_CACHE</Device_Level_Data_Caching_Mode>

      <!-- Channels, chips, dies, planes — must match ssdconfig topology -->
      <Channel_IDs>0,1,2,3,4,5,6,7</Channel_IDs>
      <Chip_IDs>0,1</Chip_IDs>
      <Die_IDs>0,1</Die_IDs>
      <Plane_IDs>0,1</Plane_IDs>

      <!-- Start at 0% occupancy for clean comparison -->
      <Initial_Occupancy_Percentage>0</Initial_Occupancy_Percentage>

      <!-- Trace file: MQSim ASCII format
           Each line: ArrivalNS  Device  StartSector  SectorCount  Type(1=Write)
      -->
      <File_Path>workloads/trace_sequential.trace</File_Path>
      <Percentage_To_Be_Executed>100</Percentage_To_Be_Executed>
      <Percentage_Of_Data_Accessed>100</Percentage_Of_Data_Accessed>
    </IO_Flow_Parameter_Set_Trace_Based>

  </IO_Scenario>
</MQSim_IO_Scenarios>
