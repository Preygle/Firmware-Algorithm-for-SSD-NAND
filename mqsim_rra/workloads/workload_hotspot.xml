<?xml version="1.0" encoding="utf-8" ?>
<!--
  workload_hotspot.xml
  =====================
  Hotspot (80/20) write workload — the primary RRA-FTL benchmark.
  80% of writes go to 20% of LBAs (hot region).
  Matches Python sim: generate_hotspot(100_000, hot_ratio=0.8, hot_fraction=0.2)

  This is the workload where RRA-FTL shows the largest improvement:
  - Baseline wear variance: ~36     (hot blocks erased 4× more than cold)
  - RRA-FTL wear variance:  ~2.7   (Weibull scoring steers GC away from hot blocks)
  - Wear variance reduction: 93%

  Run:
    ./MQSim -i ssdconfig_rra.xml      -w workloads/workload_hotspot.xml
    ./MQSim -i ssdconfig_baseline.xml -w workloads/workload_hotspot.xml

  Then compare output XMLs:
    python3 parse_mqsim_output.py \\
        workloads/workload_hotspot_scenario_1_baseline.xml \\
        workloads/workload_hotspot_scenario_1_rra.xml
-->
<MQSim_IO_Scenarios>
  <IO_Scenario>

    <IO_Flow_Parameter_Set_Trace_Based>
      <Priority_Class>URGENT</Priority_Class>
      <Device_Level_Data_Caching_Mode>NO_CACHE</Device_Level_Data_Caching_Mode>
      <Channel_IDs>0,1,2,3,4,5,6,7</Channel_IDs>
      <Chip_IDs>0,1</Chip_IDs>
      <Die_IDs>0,1</Die_IDs>
      <Plane_IDs>0,1</Plane_IDs>
      <Initial_Occupancy_Percentage>50</Initial_Occupancy_Percentage>
      <File_Path>workloads/trace_hotspot.trace</File_Path>
      <Percentage_To_Be_Executed>100</Percentage_To_Be_Executed>
      <Percentage_Of_Data_Accessed>100</Percentage_Of_Data_Accessed>
    </IO_Flow_Parameter_Set_Trace_Based>

  </IO_Scenario>
</MQSim_IO_Scenarios>
